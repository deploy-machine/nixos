# milkoutside palette — extracted from color-schemes/milkoutside.nvim
# Names match the theme's own palette. `red` (#f93a82) is the signature accent.
# Bare hex (no "#"): Hyprland wants rgb(xxxxxx); GTK/CSS apps want #xxxxxx.
{
  bg        = "040607"; # near-black background
  bgDark    = "000000";
  bgAlt     = "0f0f15"; # bg_highlight
  surface   = "1a1e2e"; # bg_dark1
  selection = "292e42"; # bg_search
  fg        = "e8e8e8";
  fgDim     = "e0e0e0"; # fg_dark
  comment   = "595959";
  border    = "303030";

  red       = "f93a82"; # signature (== error)
  red1      = "e45555"; # border_highlight
  magenta   = "e79cfb";
  purple    = "9d7cd8";
  blue      = "63c3dd";
  cyan      = "7dcfff";
  teal      = "1abc9c"; # hint
  green     = "92cf9c";
  yellow    = "f8e063";
  orange    = "ffad00";
}

